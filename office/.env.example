# Opensens Office Environment Variables
# Copy to .env.local and fill in actual values

# Gateway WebSocket address
VITE_GATEWAY_URL=ws://localhost:18789

# Gateway auth token (via `openclaw config get gateway.auth.token`)
VITE_GATEWAY_TOKEN=

# Leader FastAPI base URL (for DRVP SSE relay)
VITE_LEADER_URL=http://192.168.23.25:8100

# Paperclip REST API URL (for governance data)
VITE_PAPERCLIP_URL=http://192.168.23.25:3100

# Paperclip company ID (for DRVP + Paperclip API filtering)
VITE_DRVP_COMPANY_ID=

# Mock mode (set to true for development without real services)
# VITE_MOCK=true
