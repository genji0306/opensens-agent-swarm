# DarkLab Environment Variables Template
# Copy to ~/.darklab/.env and fill in your values
# NEVER commit this file to version control

# === Device Role ===
# Options: boss, leader, academic, experiment, lab-agent
DARKLAB_ROLE=

# === Required for ALL devices (except Boss) ===
ANTHROPIC_API_KEY=

# === Leader only ===
GOOGLE_AI_API_KEY=
TELEGRAM_BOT_TOKEN=
GATEWAY_PORT=18789
PAPERCLIP_URL=http://localhost:3100
PAPERCLIP_HOST=0.0.0.0
PAPERCLIP_PORT=3100

# === LiteLLM proxy (Docker deployments) ===
# When set, all LLM calls route through LiteLLM instead of direct APIs
LITELLM_BASE_URL=  # e.g. http://litellm:4000/v1

# === Node HTTP addresses (for direct dispatch without OpenClaw) ===
DARKLAB_ACADEMIC_HOST=  # e.g. 192.168.23.XX
DARKLAB_ACADEMIC_PORT=8200
DARKLAB_EXPERIMENT_HOST=  # e.g. 192.168.23.YY
DARKLAB_EXPERIMENT_PORT=8300

# === Academic only ===
OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=  (same as above if sharing Google account)
PERPLEXITY_API_KEY=  # Optional: leave empty to use browser automation

# === Node devices (Academic, Experiment, Lab Agent) ===
DARKLAB_LEADER_HOST=leader.local
DARKLAB_LEADER_PORT=18789

# === Boss only ===
DARKLAB_LEADER=leader.local
DARKLAB_ACADEMIC=academic.local
DARKLAB_EXPERIMENT=experiment.local

# === Version tracking ===
DARKLAB_VERSION=2.0.0
