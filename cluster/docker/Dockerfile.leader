FROM python:3.11-slim AS base

RUN pip install --no-cache-dir uv

WORKDIR /app

# Install deps first (layer caching)
COPY pyproject.toml .
RUN uv pip install --system --no-cache -e ".[leader]"

# Copy agent code
COPY agents/ agents/

# Create darklab home structure
RUN mkdir -p /root/.darklab/logs /root/.darklab/artifacts /root/.darklab/keys

ENV PYTHONPATH=/app/agents
ENV DARKLAB_HOME=/root/.darklab
ENV DARKLAB_ROLE=leader

EXPOSE 8100

CMD ["python", "-m", "leader.serve"]
